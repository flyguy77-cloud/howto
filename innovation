13. Frontend: AI modal

AiWorkflowGenerateModal.tsx

import { useState } from "react";
import {
  Box,
  Button,
  Dialog,
  DialogActions,
  DialogContent,
  DialogTitle,
  TextField,
  Typography,
  Stack,
  Alert,
} from "@mui/material";
import {
  generateWorkflowWithAi,
  AiWorkflowDraftDto,
  NodeTypeDefinitionDto,
} from "./aiWorkflowApi";
type Props = {
  open: boolean;
  onClose: () => void;
  allowedNodeTypes: NodeTypeDefinitionDto[];
  onGenerated: (draft: AiWorkflowDraftDto) => void;
};
export function AiWorkflowGenerateModal({
  open,
  onClose,
  allowedNodeTypes,
  onGenerated,
}: Props) {
  const [prompt, setPrompt] = useState("");
  const [loading, setLoading] = useState(false);
  const [lastDraft, setLastDraft] = useState<AiWorkflowDraftDto | null>(null);
  const [error, setError] = useState<string | null>(null);
  async function handleGenerate() {
    setLoading(true);
    setError(null);
    try {
      const draft = await generateWorkflowWithAi({
        prompt,
        allowedNodeTypes,
        context: {
          source: "workflow-canvas",
        },
      });
      setLastDraft(draft);
    } catch (err) {
      console.error(err);
      setError("Workflow genereren is mislukt.");
    } finally {
      setLoading(false);
    }
  }
  function handleUseDraft() {
    if (!lastDraft) return;
    onGenerated(lastDraft);
    onClose();
    setPrompt("");
    setLastDraft(null);
  }
  return (
    <Dialog open={open} onClose={onClose} fullWidth maxWidth="md">
      <DialogTitle>Generate workflow with AI</DialogTitle>
      <DialogContent>
        <Stack spacing={2} sx={{ mt: 1 }}>
          <TextField
            label="Wat moet de workflow doen?"
            multiline
            minRows={4}
            value={prompt}
            onChange={(event) => setPrompt(event.target.value)}
            placeholder="Maak een workflow die een GitLab-script laadt, uitvoert en daarna een REST-notificatie verstuurt."
            fullWidth
          />
          {error && <Alert severity="error">{error}</Alert>}
          {lastDraft && (
            <Box>
              <Typography variant="h6">{lastDraft.name}</Typography>
              <Typography variant="body2" color="text.secondary">
                {lastDraft.description}
              </Typography>
              {lastDraft.assumptions.length > 0 && (
                <Alert severity="info" sx={{ mt: 2 }}>
                  <strong>Aannames:</strong>
                  <ul>
                    {lastDraft.assumptions.map((item) => (
                      <li key={item}>{item}</li>
                    ))}
                  </ul>
                </Alert>
              )}
              {lastDraft.warnings.length > 0 && (
                <Alert severity="warning" sx={{ mt: 2 }}>
                  <strong>Waarschuwingen:</strong>
                  <ul>
                    {lastDraft.warnings.map((item) => (
                      <li key={item}>{item}</li>
                    ))}
                  </ul>
                </Alert>
              )}
            </Box>
          )}
        </Stack>
      </DialogContent>
      <DialogActions>
        <Button onClick={onClose}>Annuleren</Button>
        <Button
          onClick={handleGenerate}
          disabled={!prompt.trim() || loading}
          variant="outlined"
        >
          {loading ? "Genereren..." : "Genereer voorstel"}
        </Button>
        <Button
          onClick={handleUseDraft}
          disabled={!lastDraft}
          variant="contained"
        >
          Plaats op canvas
        </Button>
      </DialogActions>
    </Dialog>
  );
}

