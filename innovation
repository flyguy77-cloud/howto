import org.springframework.web.bind.annotation.*;
@RestController
@RequestMapping("/api/ai/workflows")
public class AiWorkflowController {
    private final WorkflowGenerationSkill workflowGenerationSkill;
    public AiWorkflowController(WorkflowGenerationSkill workflowGenerationSkill) {
        this.workflowGenerationSkill = workflowGenerationSkill;
    }
    @PostMapping("/generate")
    public ResponseEntity<WorkflowDraftDto> generateWorkflow(
            @RequestBody WorkflowGenerationRequestDto request
    ) {
        WorkflowDraftDto draft = workflowGenerationSkill.generate(request);
        return ResponseEntity.ok(draft);
    }
}

