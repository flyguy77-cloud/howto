package nl.example.workflow.ai.service;
import nl.example.workflow.ai.dto.WorkflowDraftDto;
import nl.example.workflow.ai.dto.WorkflowGenerationRequestDto;
import nl.example.workflow.ai.provider.AiProvider;
import org.springframework.stereotype.Service;
@Service
public class WorkflowGenerationSkillImpl implements WorkflowGenerationSkill {
    private final AiProvider aiProvider;
    private final WorkflowDraftValidator validator;
    public WorkflowGenerationSkillImpl(
            AiProvider aiProvider,
            WorkflowDraftValidator validator
    ) {
        this.aiProvider = aiProvider;
        this.validator = validator;
    }
    @Override
    public WorkflowDraftDto generate(WorkflowGenerationRequestDto request) {
        WorkflowDraftDto draft = aiProvider.generateWorkflowDraft(request);
        return validator.validateAndNormalize(draft, request.allowedNodeTypes());
    }
}

