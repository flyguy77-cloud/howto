7. Validator

Voor demo simpel houden. Geen cycli-detectie circus. Eerst type-checks en edge-checks.

WorkflowDraftValidator.java

package nl.example.workflow.ai.service;
import nl.example.workflow.ai.dto.AiEdgeDto;
import nl.example.workflow.ai.dto.AiNodeDto;
import nl.example.workflow.ai.dto.NodeTypeDefinitionDto;
import nl.example.workflow.ai.dto.WorkflowDraftDto;
import org.springframework.stereotype.Component;
import java.util.*;
import java.util.stream.Collectors;
@Component
public class WorkflowDraftValidator {
    public WorkflowDraftDto validateAndNormalize(
            WorkflowDraftDto draft,
            List<NodeTypeDefinitionDto> allowedNodeTypes
    ) {
        Set<String> allowedTypes = allowedNodeTypes.stream()
                .map(NodeTypeDefinitionDto::type)
                .collect(Collectors.toSet());
        Set<String> nodeIds = draft.nodes().stream()
                .map(AiNodeDto::id)
                .collect(Collectors.toSet());
        List<String> warnings = new ArrayList<>();
        if (draft.warnings() != null) {
            warnings.addAll(draft.warnings());
        }
        for (AiNodeDto node : draft.nodes()) {
            if (!allowedTypes.contains(node.type())) {
                throw new IllegalArgumentException(
                        "AI generated unsupported node type: " + node.type()
                );
            }
        }
        for (AiEdgeDto edge : draft.edges()) {
            if (!nodeIds.contains(edge.source())) {
                throw new IllegalArgumentException(
                        "AI generated edge with unknown source: " + edge.source()
                );
            }
            if (!nodeIds.contains(edge.target())) {
                throw new IllegalArgumentException(
                        "AI generated edge with unknown target: " + edge.target()
                );
            }
        }
        warnings.add("Deze workflow is AI-gegenereerd en moet gecontroleerd worden voordat hij wordt opgeslagen of uitgevoerd.");
        return new WorkflowDraftDto(
                draft.name(),
                draft.description(),
                draft.nodes(),
                draft.edges(),
                draft.assumptions(),
                warnings
        );
    }
}

