package nl.example.workflow.ai.provider;
import com.fasterxml.jackson.databind.ObjectMapper;
import nl.example.workflow.ai.dto.WorkflowDraftDto;
import nl.example.workflow.ai.dto.WorkflowGenerationRequestDto;
import org.springframework.context.annotation.Profile;
import org.springframework.stereotype.Component;
@Component
@Profile("open-ai")
public class OpenAiProvider implements AiProvider {
    private final ObjectMapper objectMapper;
    public OpenAiProvider(ObjectMapper objectMapper) {
        this.objectMapper = objectMapper;
    }
    @Override
    public WorkflowDraftDto generateWorkflowDraft(WorkflowGenerationRequestDto request) {
        String systemPrompt = buildSystemPrompt(request);
        String userPrompt = request.prompt();
        // Hier komt je daadwerkelijke AI-call.
        // Voor demo kun je dit later invullen met OpenAI, Azure OpenAI,
        // Ollama, LM Studio of een interne LLM gateway.
        String aiJsonResponse = callModel(systemPrompt, userPrompt);
        try {
            return objectMapper.readValue(aiJsonResponse, WorkflowDraftDto.class);
        } catch (Exception e) {
            throw new IllegalStateException("AI response kon niet naar WorkflowDraftDto worden gemapt", e);
        }
    }
    private String buildSystemPrompt(WorkflowGenerationRequestDto request) {
        try {
            return """
                    Je bent een Workflow Generation Skill.
                    Taak:
                    Zet de gebruikersprompt om naar een valide WorkflowDraftDto JSON.
                    Regels:
                    - Geef uitsluitend JSON terug.
                    - Gebruik alleen node types uit allowedNodeTypes.
                    - Maak altijd geldige node ids.
                    - Maak alleen edges tussen bestaande nodes.
                    - Voeg assumptions toe als je iets moet aannemen.
                    - Voeg warnings toe voor onzekerheden.
                    - Voer niets uit.
                    - Maak geen scripts.
                    - Maak geen credentials, tokens of secrets aan.
                    allowedNodeTypes:
                    %s
                    Verwachte JSON structuur:
                    {
                      "name": "string",
                      "description": "string",
                      "nodes": [
                        {
                          "id": "string",
                          "type": "string",
                          "position": { "x": 0, "y": 0 },
                          "data": {}
                        }
                      ],
                      "edges": [
                        {
                          "id": "string",
                          "source": "string",
                          "target": "string",
                          "label": "string"
                        }
                      ],
                      "assumptions": [],
                      "warnings": []
                    }
                    """.formatted(objectMapper.writeValueAsString(request.allowedNodeTypes()));
        } catch (Exception e) {
            throw new IllegalStateException("Kon system prompt niet bouwen", e);
        }
    }
    private String callModel(String systemPrompt, String userPrompt) {
        throw new UnsupportedOperationException("Nog te koppelen aan AI provider");
    }
}

