14. Canvas koppeling

In je editorpagina:

import { useState } from "react";
import { Button } from "@mui/material";
import { Node, Edge } from "@xyflow/react";
import { AiWorkflowGenerateModal } from "./AiWorkflowGenerateModal";
import { aiAllowedNodeTypes } from "./aiAllowedNodeTypes";
import { AiWorkflowDraftDto } from "./aiWorkflowApi";
export function WorkflowEditorPage() {
  const [nodes, setNodes] = useState<Node[]>([]);
  const [edges, setEdges] = useState<Edge[]>([]);
  const [aiModalOpen, setAiModalOpen] = useState(false);
  function handleAiWorkflowGenerated(draft: AiWorkflowDraftDto) {
    const generatedNodes: Node[] = draft.nodes.map((node) => ({
      id: node.id,
      type: node.type,
      position: node.position,
      data: {
        ...node.data,
        label: node.data.label ?? node.type,
      },
    }));
    const generatedEdges: Edge[] = draft.edges.map((edge) => ({
      id: edge.id,
      source: edge.source,
      target: edge.target,
      label: edge.label ?? undefined,
    }));
    setNodes(generatedNodes);
    setEdges(generatedEdges);
  }
  return (
    <>
      <Button variant="contained" onClick={() => setAiModalOpen(true)}>
        Generate workflow with AI
      </Button>
      <AiWorkflowGenerateModal
        open={aiModalOpen}
        onClose={() => setAiModalOpen(false)}
        allowedNodeTypes={aiAllowedNodeTypes}
        onGenerated={handleAiWorkflowGenerated}
      />
      {/* Hier staat jouw XYFlow canvas */}
    </>
  );
}

