import axios from "axios";
export type NodeTypeDefinitionDto = {
  type: string;
  label: string;
  requiredFields: string[];
  optionalFields: string[];
};
export type WorkflowGenerationRequestDto = {
  prompt: string;
  allowedNodeTypes: NodeTypeDefinitionDto[];
  context?: Record<string, unknown>;
};
export type AiWorkflowDraftDto = {
  name: string;
  description: string;
  nodes: AiNodeDto[];
  edges: AiEdgeDto[];
  assumptions: string[];
  warnings: string[];
};
export type AiNodeDto = {
  id: string;
  type: string;
  position: {
    x: number;
    y: number;
  };
  data: Record<string, unknown>;
};
export type AiEdgeDto = {
  id: string;
  source: string;
  target: string;
  label?: string | null;
};
export async function generateWorkflowWithAi(
  request: WorkflowGenerationRequestDto
): Promise<AiWorkflowDraftDto> {
  const response = await axios.post<AiWorkflowDraftDto>(
    "/api/ai/workflows/generate",
    request
  );
  return response.data;
}

