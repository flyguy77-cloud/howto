In welke klasse roep je dit aan?

Beste plek: WorkflowNodeExecutor

Omdat daar:
	•	RunScript node wordt afgehandeld
	•	je al weet welk script uitgevoerd moet worden
	•	je nog vóór JobExecutionService zit

Dus:

@Service
@RequiredArgsConstructor
public class WorkflowNodeExecutor {

    private final ScriptRuntimeResolver runtimeResolver;
    private final JobExecutionService jobExecutionService;
    private final JobCompletionAwaiter awaiter;

    public void execute(NodeEntity node, GraphModel graph, UUID workflowExecId) {

        switch (node.getType()) {

            case RUN_SCRIPT -> {
                UUID loadScriptNodeId = graph.resolveRequiredLoadScript(node.getId());
                NodeEntity loadScriptNode = graph.getNode(loadScriptNodeId);

                String scriptPath = loadScriptNode.getScriptPath();

                ScriptExecutionSpec spec = runtimeResolver.resolve(scriptPath);

                UUID jobExecId = jobExecutionService.executeScriptJobInternal(
                        node,
                        loadScriptNode,
                        spec,
                        workflowExecId
                );

                awaiter.await(jobExecId);
            }

            case LOAD_SCRIPT -> {
                // no-op
            }

            case END -> {
                // workflow finished
            }

            default -> throw new IllegalStateException(
                    "Unsupported node type: " + node.getType()
            );
        }
    }
}


