Nog netter: detectie op extensie + shebang

Alleen op extensie is prima voor MVP.
Maar als je straks robuuster wilt zijn, kun je:
	1.	eerst extensie checken
	2.	als onbekend: eerste regel lezen
	•	#!/usr/bin/env python
	•	#!/usr/bin/env Rscript
	•	#!/bin/bash

Dan krijg je:

@Component
public class ScriptRuntimeResolver {

    public ScriptExecutionSpec resolve(String scriptPath, String scriptContent) {
        String lower = scriptPath.toLowerCase();

        if (lower.endsWith(".py")) {
            return pythonSpec(scriptPath);
        }
        if (lower.endsWith(".r")) {
            return rSpec(scriptPath);
        }
        if (lower.endsWith(".sh")) {
            return bashSpec(scriptPath);
        }

        if (scriptContent != null && scriptContent.startsWith("#!")) {
            String firstLine = scriptContent.lines().findFirst().orElse("");
            if (firstLine.contains("python")) return pythonSpec(scriptPath);
            if (firstLine.contains("Rscript")) return rSpec(scriptPath);
            if (firstLine.contains("bash")) return bashSpec(scriptPath);
        }

        throw new IllegalStateException("Unsupported script type: " + scriptPath);
    }

    private ScriptExecutionSpec pythonSpec(String scriptPath) {
        return new ScriptExecutionSpec(
                ScriptRuntime.PYTHON,
                "my-python-runner:latest",
                List.of("python"),
                List.of(scriptPath)
        );
    }

    private ScriptExecutionSpec rSpec(String scriptPath) {
        return new ScriptExecutionSpec(
                ScriptRuntime.R,
                "my-r-runner:latest",
                List.of("Rscript"),
                List.of(scriptPath)
        );
    }

    private ScriptExecutionSpec bashSpec(String scriptPath) {
        return new ScriptExecutionSpec(
                ScriptRuntime.BASH,
                "my-bash-runner:latest",
                List.of("bash"),
                List.of(scriptPath)
        );
    }
}


